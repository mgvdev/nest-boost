{
  "name": "@mgvdev/nest-boost",
  "version": "0.3.0",
  "description": "Laravel Boost for NestJS — MCP server, AI guidelines, and agent skills that teach coding agents your Nest app.",
  "type": "module",
  "license": "MIT",
  "author": "Maxence Guyonvarho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgvdev/nest-boost.git"
  },
  "homepage": "https://github.com/mgvdev/nest-boost#readme",
  "bugs": {
    "url": "https://github.com/mgvdev/nest-boost/issues"
  },
  "bin": {
    "nest-boost": "./dist/cli.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --target=node --format=esm --packages=external --outdir=dist && bun run scripts/postbuild.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run typecheck && bun test"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "mcp",
    "ai",
    "claude",
    "cursor",
    "boost",
    "agent"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tsx": "^4.19.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0",
    "better-sqlite3": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@types/bun": "latest",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.4.0"
  }
}
